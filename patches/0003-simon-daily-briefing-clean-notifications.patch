+fn routine_notification_content(
+    icon: &str,
+    routine_name: &str,
+    status: RunStatus,
+    summary: Option<&str>,
+) -> String {
+    if let Some(summary) = summary
+        && status == RunStatus::Attention
+        && is_final_simon_daily_briefing(routine_name, summary)
+    {
+        return summary.to_string();
+    }
+
+    match summary {
+        Some(s) => format!("{} *Routine '{}'*: {}\n\n{}", icon, routine_name, status, s),
+        None => format!("{} *Routine '{}'*: {}", icon, routine_name, status),
+    }
+}
+
+fn is_final_simon_daily_briefing(routine_name: &str, summary: &str) -> bool {
+    routine_name.starts_with("daily-briefing-")
+        && (summary.contains("תדריך משפחתי") || summary.contains("Family Briefing"))
+}
