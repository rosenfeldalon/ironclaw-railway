+
+fn normalize_simon_identity(value: &str) -> Option<String> {
+    let trimmed = value.trim().to_ascii_lowercase();
+    if trimmed.is_empty() {
+        return None;
+    }
+
+    if trimmed
+        .chars()
+        .all(|ch| ch.is_ascii_lowercase() || ch.is_ascii_digit() || ch == '_' || ch == '-')
+    {
+        Some(trimmed)
+    } else {
+        None
+    }
+}
+
+fn looks_like_explicit_telegram_target(value: &str) -> bool {
