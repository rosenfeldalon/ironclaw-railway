+++ b/src/agent/agent_loop.rs
@@ -139,6 +139,19 @@ fn resolve_owner_scope_notification_user(
     trimmed_option(explicit_user).or_else(|| trimmed_option(owner_fallback))
 }
 
+fn prefers_channel_notification_target(
+    explicit_user: Option<&str>,
+    owner_fallback: Option<&str>,
+) -> bool {
+    let explicit = trimmed_option(explicit_user);
+    let owner = trimmed_option(owner_fallback);
+
+    match explicit {
+        None => true,
+        Some(explicit_target) => owner.is_some_and(|owner_target| explicit_target == owner_target),
+    }
+}
