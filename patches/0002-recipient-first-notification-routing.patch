+fn prefers_channel_notification_target(
+    explicit_target: Option<&str>,
+    owner_scope_target: Option<&str>,
+) -> bool {
+    match (
+        explicit_target.map(str::trim).filter(|value| !value.is_empty()),
+        owner_scope_target
+            .map(str::trim)
+            .filter(|value| !value.is_empty()),
+    ) {
+        (None, _) => true,
+        (Some(explicit), Some(owner_scope)) => explicit == owner_scope,
+        (Some(_), None) => false,
+    }
+}
